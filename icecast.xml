<icecast>
  <location>Earth</location>
  <admin>admin@ai-fm-radio.local</admin>
  <limits>
    <clients>100</clients>
    <sources>5</sources>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
    <burst-on-connect>1</burst-on-connect>
    <burst-size>65535</burst-size>
  </limits>
  <authentication>
    <source-password>hackme</source-password>
    <relay-password>hackme</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>admin123</admin-password>
  </authentication>
  <hostname>localhost</hostname>
  <listen-socket>
    <port>8000</port>
  </listen-socket>
  <http-headers>
    <header><name>Access-Control-Allow-Origin</name><value>*</value></header>
  </http-headers>
  <mount type="normal">
    <mount-name>/radio</mount-name>
    <stream-name>AI FM 99.9</stream-name>
    <stream-description>The Future of Radio</stream-description>
    <stream-url>http://localhost:4200</stream-url>
    <genre>AI Electronic</genre>
    <bitrate>128</bitrate>
    <type>audio/mpeg</type>
    <public>1</public>
  </mount>
  <fileserve>1</fileserve>
  <paths>
    <basedir>/usr/share/icecast2</basedir>
    <logdir>/var/log/icecast2</logdir>
    <webroot>/usr/share/icecast2/web</webroot>
    <adminroot>/usr/share/icecast2/admin</adminroot>
    <alias source="/" destination="/status.xsl"/>
  </paths>
  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
    <logsize>10000</logsize>
  </logging>
  <security>
    <chroot>0</chroot>
  </security>
</icecast>
