# ── App ──────────────────────────────────────────────────────────────────
APP_NAME="AI FM Radio"
DEBUG=false

# ── CORS ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:4200"]

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./fm_radio.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fm_radio

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Services ──────────────────────────────────────────────────────────
# OpenAI (GPT-4o for DJ scripts)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ElevenLabs (AI DJ voice synthesis)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Anthropic Claude (optional secondary LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Suno (AI music generation - add when API is available)
SUNO_API_KEY=...

# ── Audio / Icecast Stream ────────────────────────────────────────────────
ICECAST_HOST=localhost
ICECAST_PORT=8000
ICECAST_MOUNT=/radio
ICECAST_PASSWORD=hackme

# ── Station Identity ──────────────────────────────────────────────────────
STATION_NAME="AI FM 99.9"
STATION_TAGLINE="The Future of Radio"
DEFAULT_GENRE="Chill Electronic"
